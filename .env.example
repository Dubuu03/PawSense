# Firebase Configuration Template
# Copy this file to .env and fill in your actual Firebase configuration values

FIREBASE_WEB_API_KEY=your_web_api_key_here
FIREBASE_WEB_APP_ID=your_web_app_id_here
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
FIREBASE_PROJECT_ID=your_project_id_here
FIREBASE_AUTH_DOMAIN=your_auth_domain_here
FIREBASE_STORAGE_BUCKET=your_storage_bucket_here
FIREBASE_MEASUREMENT_ID=your_measurement_id_here

FIREBASE_ANDROID_API_KEY=your_android_api_key_here
FIREBASE_ANDROID_APP_ID=your_android_app_id_here

# EmailJS Configuration for OTP emails
EMAILJS_PUBLIC_KEY=your_emailjs_public_key_here

# Backend Endpoint
RAILWAY_ENDPOINT=https://your-backend-url

# Groq AI Configuration
GROQ_ENABLED=true
GROQ_API_KEY=your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_PRIMARY_MODEL_TRIAGE=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_FALLBACK_MODEL_TRIAGE=llama-3.3-70b-versatile
GROQ_BACKUP_MODELS_TRIAGE=qwen/qwen3-32b,openai/gpt-oss-20b,llama-3.1-8b-instant
GROQ_PRIMARY_MODEL_RECO=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL_RECO=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_BACKUP_MODELS_RECO=openai/gpt-oss-20b,qwen/qwen3-32b,llama-3.1-8b-instant
GROQ_TIMEOUT_MS=9000
GROQ_MAX_RETRIES=0
GROQ_RATE_LIMIT_COOLDOWN_MS=15000
GROQ_MODEL_UNAVAILABLE_COOLDOWN_MIN=360
GROQ_DAILY_CALL_CAP=2500